// Flatbuffer serialisation for Airday messages & objects

namespace proto;

struct LWWTimestamp {
  utc: double;
  pid: double;
  tick: short;
}

struct UUID {
  bytes: [ubyte:16];
}

table LWWRegisterString {
  timestamp: LWWTimestamp;
  value: string;
}

struct LWWRegisterBool {
  timestamp: LWWTimestamp;
  value: bool;
}

table Item {
  id: UUID (required);
  text: LWWRegisterString;
  completed: LWWRegisterBool;
}

table DeleteItemAction {
  id: [ubyte];
}

table AddItemAction {
  item: Item;
}

union AirdayAction {
  AddItemAction,
  DeleteItemAction,
}

table AirdayBatchComponent {
  action: AirdayAction;
}

table AirdayMessage {
  batch: [AirdayBatchComponent];
}

// Currently, simply a wrapper for JSON encoded message
table JMAPMessage {
  payload: string;
}

union Message {
  AirdayMessage,
  JMAPMessage,
}

table TraceContext {
  trace_id: string;
  span_id: string;
  parent_span_id: string;
  timestamp: uint64;
}

table MessageWrapper {
  message: Message;
  ctx: TraceContext;
}

root_type MessageWrapper;
root_type AirdayMessage;
