// Airday-specific object encoding
include "common.fbs";

namespace AirdayProto;

struct LWWTimestampProto {
  utc: long;
  pid: long;
}

table ItemProto {
  version: short;
  id: CommonProto.UuidProto (required);
  name: string;
}

root_type ItemProto;

table EventProto {
  version: short;
  id: CommonProto.UuidProto (required);
  name: string;
}

root_type EventProto;
