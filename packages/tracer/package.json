{
  "name": "@airday/tracer",
  "version": "0.0.1",
  "description": "Ultra-light tracing. OpenTelemetry compatible, hopefully.",
  "main": "dist/tracer.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "bun test",
    "build": "bun run bundle.ts",
    "dev": "bun run bundle.ts --watch",
    "clean": "rm -rf dist",
    "ts": "tsc --declaration --emitDeclarationOnly --outDir dist src/index.ts",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "exports": {
    ".": {
      "import": "./dist/tracer.esm.js",
      "types": "./dist/tracer.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
