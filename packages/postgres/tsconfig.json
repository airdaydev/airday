{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": false,
    "strict": false,
    "outDir": "dist",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".eslinrc.cjs",
    "src/**/*.spec.*"
  ]
}
