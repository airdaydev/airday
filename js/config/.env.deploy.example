# Deploy secrets file. Lives at /opt/airday/.env on the server (mode 0600,
# owned by airday:airday). Read by `bun run config:deploy` during ci.sh.
#
# Copy this to /opt/airday/.env and fill in the required values.

# Public hostname Caddy serves on. Caddy will provision a Let's Encrypt
# certificate via HTTP-01 — make sure 80/443 are reachable from the
# internet and DNS already points here before deploying.
AIRDAY_HOST=airday.example.com

# Account email for Let's Encrypt registration / renewal notices.
CADDY_EMAIL=you@example.com

# ---- optional overrides — defaults shown ------------------------------

# Bind address for airday-server. Loopback only — Caddy reverse-proxies.
# AIRDAY_BIND=127.0.0.1:8000

# Sqlite path. Must be inside /var/lib/airday (the systemd unit's only
# writable path) unless you also widen ReadWritePaths in airday.service.
# AIRDAY_DB_PATH=/var/lib/airday/airday.sqlite

# AIRDAY_LOG_LEVEL=info

# Set the Secure attribute on the device-auth cookie. Must be true behind
# Caddy's TLS — only flip to false for plain-HTTP alpha.
# AIRDAY_SECURE_COOKIES=true
