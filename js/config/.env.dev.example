# Copy to js/config/.env and edit. Every key is optional; defaults are
# applied in gen-config.ts (buildDevEnv) or by airday-server itself.

# AIRDAY_BIND=127.0.0.1:8080
# AIRDAY_LOG_LEVEL=info

# Server default: $XDG_DATA_HOME/airday/airday.sqlite, falling back to
# $HOME/.local/share/airday/airday.sqlite. Set this only to override.
# AIRDAY_DB_PATH=
