# Copy to js/config/.env and edit. Every key is optional; defaults are
# applied in gen-config.ts (buildDevEnv) or by airday-server itself.

# AIRDAY_BIND=127.0.0.1:8080
# AIRDAY_LOG_LEVEL=info

# Set the `Secure` attribute on the device-auth cookie. Dev default is
# `false` because Safari refuses to store/send Secure cookies on
# `http://localhost`. Flip to `true` once you're behind TLS.
# AIRDAY_SECURE_COOKIES=false

# Server default: $XDG_DATA_HOME/airday/airday.sqlite, falling back to
# $HOME/.local/share/airday/airday.sqlite. Set this only to override.
# AIRDAY_DB_PATH=

# The dev stack runs behind Caddy with TLS so WebCrypto works from any
# device on the mesh (see local/Caddyfile). The default hostname is wired
# to my dev box; override these to point at yours. Caddy provisions a
# wildcard cert for DEV_PROXY_DOMAIN via Let's Encrypt DNS-01 using
# CLOUDFLARE_API_TOKEN from your shell environment at run time.
# DEV_PROXY_HOSTNAME=macbook.yokoso.golf

# Parent domain for the wildcard cert (`*.<domain>`). Defaults to the parent
# of DEV_PROXY_HOSTNAME (label stripped); set explicitly only for multi-label
# TLDs like `co.uk`.
# DEV_PROXY_DOMAIN=yokoso.golf
